{
  "name": "John Chezik - Platinum-Selling Artist",
  "short_name": "John Chezik",
  "description": "Official website of John Chezik - platinum-selling songwriter-singer, guitar player and published author with 6 albums and 2 books",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#007aff",
  "orientation": "portrait-primary",
  "categories": ["music", "entertainment", "books"],
  "lang": "en",
  "dir": "ltr",
  "scope": "/",
