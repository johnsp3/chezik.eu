{
  "version": 2,
  "routes": [
    {
      "src": "/api/audio/stream/(.*)",
      "dest": "/api/audio/stream/$1",
      "headers": {
        "Cache-Control": "public, max-age=3600, s-maxage=86400"
      }
    },
    {
      "src": "/api/audio/analytics",
      "dest": "/api/audio/analytics",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "src": "/api/contact",
      "dest": "/api/contact",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "src": "/api/email/(.*)",
      "dest": "/api/email/$1",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "src": "/api/newsletter",
      "dest": "/api/newsletter",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "src": "/(.*\\.(mp3|wav|ogg|m4a))",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable",
        "Content-Type": "audio/mpeg"
      }
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|gif|webp|avif|svg))",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*\\.(css|js|woff|woff2|ttf|eot))",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "functions": {
    "src/app/api/audio/stream/[id]/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/audio/analytics/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/contact/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/email/preferences/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/email/unsubscribe/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/newsletter/route.ts": {
      "maxDuration": 15
    }
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "regions": ["iad1", "sfo1", "lhr1"],
  "framework": "nextjs"
}